<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<!--
	  App Transport Security blocks cleartext HTTP by default. The dev server
	  runs on the host machine over plain HTTP, reached via `localhost` from
	  the iOS simulator. `NSAllowsLocalNetworking` clears cleartext for
	  loopback and .local hostnames only; everything else still requires HTTPS.
	-->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
</dict>
</plist>
